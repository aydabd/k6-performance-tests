  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "jsdoc-to-markdown": "^9.1.3",
    "markdownlint-cli": "^0.47.0",
