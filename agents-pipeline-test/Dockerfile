# syntax=docker/dockerfile:1
################################################################################
# Title: Dockerfile for agents-pipeline-test — real k6 test from agent pipeline
# Author: Aydin Abdi <ayd.abd@gmail.com>
# License: MIT
#
# Description:
#   Packages the k6 script generated by the WP-12 agent pipeline (ANALYZE →
#   PLAN → GENERATE) into a runnable Docker image, using the same base image
#   pattern as the other test templates.
#
# Build (base image must be built first):
#   docker build -t k6-template-influxdb-base:latest .
#   docker build -t agents-pipeline-test:latest -f agents-pipeline-test/Dockerfile .
#
# Run:
#   docker run --rm -e API_SERVER=dogapi.dog agents-pipeline-test:latest
################################################################################
ARG BASE_IMAGE_NAME="k6-template-influxdb-base"
ARG BASE_IMAGE_VERSION="latest"
FROM $BASE_IMAGE_NAME:$BASE_IMAGE_VERSION

ARG IMAGE_NAME="agents-pipeline-test"
ARG IMAGE_VERSION="latest"

LABEL image.name="${IMAGE_NAME}" \
      image.version="${IMAGE_VERSION}" \
      image.tag="${IMAGE_NAME}:${IMAGE_VERSION}" \
      description="k6 test generated by the WP-12 agent pipeline (ANALYZE→PLAN→GENERATE)."

ARG WORK_DIR="/performance-k6"
ARG PERFORMANCE_K6_TEST_FOLDER_NAME="agents-pipeline-test"
ARG PERFORMANCE_K6_TEST_FILE_PATH="./${PERFORMANCE_K6_TEST_FOLDER_NAME}/agent-test.js"
ARG PERFORMANCE_K6_OPTION_CONFIG_PATH="${WORK_DIR}/k6-config-options/default-test-config.json"
ARG PERFORMANCE_K6_TEST_LOG_DIR_NAME="test-logs"
ARG API_SERVER="dogapi.dog"

ARG K6_OUT="xk6-influxdb=http://influxdb:8086" \
    K6_CONSOLE_OUTPUT="${WORK_DIR}/${PERFORMANCE_K6_TEST_LOG_DIR_NAME}/${PERFORMANCE_K6_TEST_FOLDER_NAME}_console.log" \
    K6_LOG_OUTPUT="file=${WORK_DIR}/${PERFORMANCE_K6_TEST_LOG_DIR_NAME}/${PERFORMANCE_K6_TEST_FOLDER_NAME}_json.log" \
    K6_LOG_FORMAT="json" \
    K6_LOG_LEVEL="info" \
    K6_NO_USAGE_REPORT="true"

ENV PERFORMANCE_K6_TEST_FOLDER_NAME="${PERFORMANCE_K6_TEST_FOLDER_NAME}" \
    PERFORMANCE_K6_TEST_FILE_PATH="${PERFORMANCE_K6_TEST_FILE_PATH}" \
    PERFORMANCE_K6_OPTION_CONFIG_PATH="${PERFORMANCE_K6_OPTION_CONFIG_PATH}" \
    PERFORMANCE_K6_TEST_LOG_DIR_NAME="${PERFORMANCE_K6_TEST_LOG_DIR_NAME}" \
    API_SERVER="${API_SERVER}" \
    K6_OUT="${K6_OUT}" \
    K6_CONSOLE_OUTPUT="${K6_CONSOLE_OUTPUT}" \
    K6_LOG_OUTPUT="${K6_LOG_OUTPUT}" \
    K6_LOG_FORMAT="${K6_LOG_FORMAT}" \
    K6_LOG_LEVEL="${K6_LOG_LEVEL}" \
    K6_NO_USAGE_REPORT="${K6_NO_USAGE_REPORT}"

# TODO: The influxdb token should be set as a secret and should be removed from the Dockerfile
# This token connects the influxdb datasource for Grafana in local/CI environments only.
# The same token is used in grafana/datasources/datasource.yaml and the other test Dockerfiles.
ENV K6_INFLUXDB_TOKEN=y3zTEWhDLPfa05-op-gKftVHhbEkmNL98uijqokTMr_JHdlK59PpitKl6QdXNF3YQVrLXdtTdjISNSqWtFwbFw==

WORKDIR "${WORK_DIR}"

COPY --chown=k6:k6 ./"${PERFORMANCE_K6_TEST_FOLDER_NAME}" ./"${PERFORMANCE_K6_TEST_FOLDER_NAME}"

VOLUME "${WORK_DIR}/${PERFORMANCE_K6_TEST_LOG_DIR_NAME}"

EXPOSE 8086

ENTRYPOINT ["sh", "-c", "k6 run --config ${PERFORMANCE_K6_OPTION_CONFIG_PATH} ${PERFORMANCE_K6_TEST_FILE_PATH}"]
